# Supabase sync is optional. It turns on automatically when real values are set.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Optional override. Set false to force local URL-hash mode even with keys set.
# VITE_ENABLE_SUPABASE_SYNC=false
